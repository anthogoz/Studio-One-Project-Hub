# Auto-detect text files and normalize line endings
* text=auto

# JavaScript / JSX
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Shell / config
*.sh         text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf

# Binary files - never modify line endings
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    binary
*.icns   binary
*.exe    binary
*.dmg    binary
*.AppImage binary
*.zip    binary
